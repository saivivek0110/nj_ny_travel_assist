# Travel Agent for Work - Environment Configuration

# ============= API KEYS =============
# Tavily Search API (required for web search)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxx

# ============= LLM CONFIGURATION =============
# Option A — Unified (recommended): auto-detects provider from model name
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=AIza...

# Option B — Explicit provider (legacy, still works):
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Supported model prefixes:
#   claude-*                  → Anthropic  (needs ANTHROPIC_API_KEY or LLM_API_KEY)
#   gpt-*, o1-*, o3-*, o4-*  → OpenAI     (needs OPENAI_API_KEY or LLM_API_KEY)
#   gemini-*                  → Google     (needs GEMINI_API_KEY or LLM_API_KEY)
#   mistral-*, mixtral-*      → Mistral    (needs MISTRAL_API_KEY or LLM_API_KEY)
#   command-*, c4ai-*         → Cohere     (needs COHERE_API_KEY or LLM_API_KEY)

# Provider-specific keys (used with Option B)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash
# MISTRAL_API_KEY=xxxxxxxxxxxxx
# MISTRAL_MODEL=mistral-small-latest
# COHERE_API_KEY=xxxxxxxxxxxxx
# COHERE_MODEL=command-r-plus

# LLM Parameters
TEMPERATURE=0.7
MAX_TOKENS=4096

# ============= GMAIL AUTHENTICATION (optional) =============
# Gmail is optional — if not configured, reports are saved as HTML files instead.
# Run setup_auth.py to enable Gmail sending.
# Path to credentials.json (from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json

# Path to token.json (auto-generated after first authentication)
GMAIL_TOKEN_PATH=token.json

# ============= AGENT BEHAVIOR =============
VERBOSE=true
MAX_ITERATIONS=10
SEARCH_MAX_RESULTS=5
SEARCH_DAYS_AHEAD=7

# ============= COMMUTE ROUTE =============
ORIGIN_LOCATION=Your City, State
DESTINATION_LOCATION=Destination City

# Default transport mode: nj_transit, path, bus, subway, car
DEFAULT_TRANSPORT_MODE=nj_transit

# ============= DEFAULT EMAIL =============
# Leave empty if Gmail is not configured
DEFAULT_EMAIL=
